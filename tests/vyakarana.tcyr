# vyakarana test suite
# Stdlib auto-included via cyrius.cyml.
#
# M0 (palette + record): token kinds exist and are sequential;
# kind_name round-trips; kind_is_valid bounds hold.
#
# M1 (shell grammar): shell dispatch is wired; tokenize_shell
# produces known tokens at known offsets for small inputs and
# holds the coverage invariant.

include "src/token.cyr"
include "src/grammar.cyr"
include "src/tokenize.cyr"

# Coverage-invariant helper: sum of every token's len equals src_len.
# Used across M1 assertions to catch gap/overlap bugs early.
fn tb_coverage_sum(tb) {
    var n = tokenbuf_count(tb);
    var i = 0;
    var sum: i64 = 0;
    while (i < n) {
        sum = sum + tokenbuf_len(tb, i);
        i = i + 1;
    }
    return sum;
}

fn main() {
    alloc_init();

    test_group("token kinds exist and are sequential");
    assert_eq(TK_IDENT,        0, "TK_IDENT = 0");
    assert_eq(TK_KEYWORD,      1, "TK_KEYWORD = 1");
    assert_eq(TK_STRING,       2, "TK_STRING = 2");
    assert_eq(TK_NUMBER,       3, "TK_NUMBER = 3");
    assert_eq(TK_COMMENT,      4, "TK_COMMENT = 4");
    assert_eq(TK_OPERATOR,     5, "TK_OPERATOR = 5");
    assert_eq(TK_PUNCTUATION,  6, "TK_PUNCTUATION = 6");
    assert_eq(TK_WHITESPACE,   7, "TK_WHITESPACE = 7");
    assert_eq(TK_PREPROCESSOR, 8, "TK_PREPROCESSOR = 8");
    assert_eq(TK_ERROR,        9, "TK_ERROR = 9");
    assert_eq(TK_COUNT,       10, "TK_COUNT = 10");

    test_group("kind_name round-trips each kind");
    assert_eq(streq(kind_name(TK_IDENT),        "ident"),        1, "ident");
    assert_eq(streq(kind_name(TK_KEYWORD),      "keyword"),      1, "keyword");
    assert_eq(streq(kind_name(TK_STRING),       "string"),       1, "string");
    assert_eq(streq(kind_name(TK_NUMBER),       "number"),       1, "number");
    assert_eq(streq(kind_name(TK_COMMENT),      "comment"),      1, "comment");
    assert_eq(streq(kind_name(TK_OPERATOR),     "operator"),     1, "operator");
    assert_eq(streq(kind_name(TK_PUNCTUATION),  "punctuation"),  1, "punctuation");
    assert_eq(streq(kind_name(TK_WHITESPACE),   "whitespace"),   1, "whitespace");
    assert_eq(streq(kind_name(TK_PREPROCESSOR), "preprocessor"), 1, "preprocessor");
    assert_eq(streq(kind_name(TK_ERROR),        "error"),        1, "error");

    test_group("kind_is_valid bounds");
    assert_eq(kind_is_valid(0 - 1),       0, "negative is invalid");
    assert_eq(kind_is_valid(0),           1, "0 is valid");
    assert_eq(kind_is_valid(TK_COUNT - 1),1, "TK_COUNT-1 is valid");
    assert_eq(kind_is_valid(TK_COUNT),    0, "TK_COUNT is invalid");
    assert_eq(kind_is_valid(99),          0, "99 is invalid");

    test_group("M1 grammar registry");
    assert_eq(has_grammar("shell"),  1, "shell loaded in M1");
    assert_eq(has_grammar("zig"), 0, "zig not yet loaded");
    assert_eq(has_grammar(""),    0, "empty name not loaded");

    test_group("tokenize_source returns empty (0) for unknown languages");
    assert_eq(tokenize_source("x", "zig"),    0, "zig not yet loaded");
    assert_eq(tokenize_source("x", "go"),     0, "go not yet loaded");

    test_group("M1 shell grammar — known-offset assertions");
    # Input: `if true; then echo hi; fi`
    # Expected tokens (in order):
    #   [kw:if @0,2] [ws @2,1] [id:true @3,4] [punc:; @7,1] [ws @8,1]
    #   [kw:then @9,4] [ws @13,1] [id:echo @14,4] [ws @18,1] [id:hi @19,2]
    #   [punc:; @21,1] [ws @22,1] [kw:fi @23,2]
    var tb1 = tokenize_source("if true; then echo hi; fi", "shell");
    assert_neq(tb1, 0, "tokenbuf allocated");
    assert_eq(tokenbuf_count(tb1), 13, "13 tokens for the sample line");

    assert_eq(tokenbuf_kind(tb1, 0),  TK_KEYWORD,     "tok0 is keyword");
    assert_eq(tokenbuf_start(tb1, 0), 0,              "tok0 starts at 0");
    assert_eq(tokenbuf_len(tb1, 0),   2,              "tok0 len 2 (`if`)");

    assert_eq(tokenbuf_kind(tb1, 1),  TK_WHITESPACE,  "tok1 whitespace");
    assert_eq(tokenbuf_kind(tb1, 2),  TK_IDENT,       "tok2 ident (`true`)");
    assert_eq(tokenbuf_len(tb1, 2),   4,              "tok2 len 4");
    assert_eq(tokenbuf_kind(tb1, 3),  TK_PUNCTUATION, "tok3 `;`");
    assert_eq(tokenbuf_kind(tb1, 5),  TK_KEYWORD,     "tok5 `then`");
    assert_eq(tokenbuf_len(tb1, 5),   4,              "tok5 len 4");
    assert_eq(tokenbuf_kind(tb1, 12), TK_KEYWORD,     "tok12 `fi`");
    assert_eq(tokenbuf_len(tb1, 12),  2,              "tok12 len 2");

    # Coverage invariant on the same input.
    assert_eq(tb_coverage_sum(tb1), 25, "coverage sum == strlen");

    test_group("M1 shell grammar — shebang and comments");
    # `#!/bin/sh\n# comment\nx`
    var tb2 = tokenize_source("#!/bin/sh\n# comment\nx", "shell");
    assert_neq(tb2, 0, "tokenbuf allocated");
    assert_eq(tokenbuf_kind(tb2, 0),  TK_PREPROCESSOR, "shebang is preprocessor");
    assert_eq(tokenbuf_start(tb2, 0), 0,               "shebang starts at 0");
    assert_eq(tokenbuf_len(tb2, 0),   9,               "shebang len 9 (stops at \\n)");
    assert_eq(tokenbuf_kind(tb2, 1),  TK_WHITESPACE,   "newline after shebang");
    assert_eq(tokenbuf_kind(tb2, 2),  TK_COMMENT,      "line 2 is comment");
    assert_eq(tokenbuf_len(tb2, 2),   9,               "comment len 9 (`# comment`)");
    assert_eq(tb_coverage_sum(tb2),   21,              "coverage holds");

    test_group("M1 shell grammar — strings (single and double)");
    var tb3 = tokenize_source("x=\"a b\" y='c d'", "shell");
    assert_neq(tb3, 0, "tokenbuf allocated");
    # x =  "a b"  space  y  =  'c d'
    # 0 1  2..6  7      8  9  10..14
    assert_eq(tokenbuf_kind(tb3, 0),  TK_IDENT,   "x ident");
    assert_eq(tokenbuf_kind(tb3, 1),  TK_OPERATOR, "= operator");
    assert_eq(tokenbuf_kind(tb3, 2),  TK_STRING,  "\"a b\" string");
    assert_eq(tokenbuf_len(tb3, 2),   5,          "double-quoted string len 5");
    assert_eq(tokenbuf_kind(tb3, 6),  TK_STRING,  "'c d' string");
    assert_eq(tokenbuf_len(tb3, 6),   5,          "single-quoted string len 5");
    assert_eq(tb_coverage_sum(tb3),   15,         "coverage holds");

    test_group("M1 shell grammar — numbers (decimal, hex)");
    var tb4 = tokenize_source("42 0xff 0b10 0o7", "shell");
    assert_neq(tb4, 0, "tokenbuf allocated");
    assert_eq(tokenbuf_kind(tb4, 0),  TK_NUMBER, "42 is number");
    assert_eq(tokenbuf_len(tb4, 0),   2,         "42 len 2");
    assert_eq(tokenbuf_kind(tb4, 2),  TK_NUMBER, "0xff is number");
    assert_eq(tokenbuf_len(tb4, 2),   4,         "0xff len 4");
    assert_eq(tokenbuf_kind(tb4, 4),  TK_NUMBER, "0b10 is number");
    assert_eq(tokenbuf_len(tb4, 4),   4,         "0b10 len 4");
    assert_eq(tokenbuf_kind(tb4, 6),  TK_NUMBER, "0o7 is number");
    assert_eq(tokenbuf_len(tb4, 6),   3,         "0o7 len 3");
    assert_eq(tb_coverage_sum(tb4),   16,        "coverage holds");

    test_group("M1 shell grammar — operators and [[ ]]");
    var tb5 = tokenize_source("[[ a != b ]] && c || d", "shell");
    assert_neq(tb5, 0, "tokenbuf allocated");
    assert_eq(tokenbuf_kind(tb5, 0),  TK_PUNCTUATION, "[[ punctuation");
    assert_eq(tokenbuf_len(tb5, 0),   2,              "[[ len 2");
    # Find the != token (index 4: [[, ws, a, ws, !=)
    assert_eq(tokenbuf_kind(tb5, 4),  TK_OPERATOR,    "!= operator");
    assert_eq(tokenbuf_len(tb5, 4),   2,              "!= len 2");
    assert_eq(tb_coverage_sum(tb5),   22,             "coverage holds");

    test_group("M1 shell grammar — no error tokens on these inputs");
    # Every byte must land in a non-error kind for a passing grammar.
    # This would catch a regression where the recognizer priority
    # accidentally skips a common byte.
    var tb6 = tokenize_source("if [[ $x -eq 42 ]]; then echo \"$x\"; fi", "shell");
    assert_neq(tb6, 0, "tokenbuf allocated");
    var n6 = tokenbuf_count(tb6);
    var i6 = 0;
    var errors6 = 0;
    while (i6 < n6) {
        if (tokenbuf_kind(tb6, i6) == TK_ERROR) { errors6 = errors6 + 1; }
        i6 = i6 + 1;
    }
    assert_eq(errors6, 0, "zero error tokens on common construct");
    assert_eq(tb_coverage_sum(tb6), 38, "coverage holds");

    test_group("tokenbuf internals");
    # Fresh tokenbuf is empty.
    var tb7 = tokenbuf_new();
    assert_eq(tokenbuf_count(tb7), 0, "new tokenbuf is empty");
    tokenbuf_push(tb7, TK_IDENT, 0, 3);
    tokenbuf_push(tb7, TK_WHITESPACE, 3, 1);
    assert_eq(tokenbuf_count(tb7), 2, "count after 2 pushes");
    assert_eq(tokenbuf_kind(tb7, 0),  TK_IDENT,      "slot 0 kind");
    assert_eq(tokenbuf_start(tb7, 0), 0,             "slot 0 start");
    assert_eq(tokenbuf_len(tb7, 0),   3,             "slot 0 len");
    assert_eq(tokenbuf_kind(tb7, 1),  TK_WHITESPACE, "slot 1 kind");
    assert_eq(tokenbuf_start(tb7, 1), 3,             "slot 1 start");

    test_group("M2 grammar loader — shell.cyml parses cleanly");
    var gshell = grammar_load("grammars/shell.cyml");
    assert_neq(gshell, 0, "grammar_load returned non-null");
    assert_eq(streq(grammar_name(gshell), "shell"), 1, "name is 'shell'");
    assert_eq(grammar_shebang_on(gshell),      1, "shebang default enabled");
    assert_eq(grammar_whitespace_on(gshell),   1, "whitespace default enabled");
    assert_eq(grammar_number_decimal(gshell),  1, "number_decimal enabled");
    assert_eq(grammar_number_0x(gshell),       1, "number_0x enabled");
    assert_eq(grammar_number_0b(gshell),       1, "number_0b enabled");
    assert_eq(grammar_number_0o(gshell),       1, "number_0o enabled");
    assert_eq(grammar_special_vars(gshell),    1, "special_vars enabled");

    var exts = grammar_extensions(gshell);
    assert_eq(vec_len(exts), 2, "2 extensions loaded");
    assert_eq(streq(vec_get(exts, 0), ".sh"),   1, "ext[0] == '.sh'");
    assert_eq(streq(vec_get(exts, 1), ".bash"), 1, "ext[1] == '.bash'");

    var ops = grammar_operators(gshell);
    assert(vec_len(ops) > 0, "operators list non-empty");
    assert_eq(streq(vec_get(ops, 0), "<<<"), 1, "operators[0] == '<<<' (longest first)");

    var lrs = grammar_line_rules(gshell);
    var prs = grammar_pair_rules(gshell);
    var wrs = grammar_words_rules(gshell);
    assert_eq(vec_len(lrs), 1, "1 line rule (# comment)");
    assert_eq(vec_len(prs), 2, "2 pair rules (\" and ')");
    assert_eq(vec_len(wrs), 1, "1 words rule (keywords)");

    var kw = vec_get(wrs, 0);
    assert_eq(words_rule_kind(kw), TK_KEYWORD, "words rule kind is keyword");
    assert_eq(vec_len(words_rule_words(kw)), 19, "19 shell keywords");

    test_group("M2 char-class tables");
    var cc = char_class_new("A-Za-z_");
    assert_eq(char_class_match(cc, 65), 1, "A matches");   # A
    assert_eq(char_class_match(cc, 90), 1, "Z matches");   # Z
    assert_eq(char_class_match(cc, 97), 1, "a matches");   # a
    assert_eq(char_class_match(cc, 122), 1, "z matches");  # z
    assert_eq(char_class_match(cc, 95), 1, "_ matches");   # _
    assert_eq(char_class_match(cc, 48), 0, "0 does not match"); # 0
    assert_eq(char_class_match(cc, 32), 0, "space does not match");

    test_group("M2 data-driven scanner matches hand-coded on small inputs");
    # Same fixture strings as the M1 suite, now run through both
    # tokenizers; counts and first-few kinds must agree.
    var probe_inputs = vec_new();
    vec_push(probe_inputs, "if true; then echo hi; fi");
    vec_push(probe_inputs, "#!/bin/sh\n# comment\nx");
    vec_push(probe_inputs, "x=\"a b\" y='c d'");
    vec_push(probe_inputs, "42 0xff 0b10 0o7");
    vec_push(probe_inputs, "[[ a != b ]] && c || d");
    var pi = 0;
    while (pi < vec_len(probe_inputs)) {
        var inp = vec_get(probe_inputs, pi);
        var tb_hand = tokenbuf_new();
        tokenize_shell(inp, strlen(inp), tb_hand);
        var tb_data = tokenbuf_new();
        tokenize_with_grammar(gshell, inp, strlen(inp), tb_data);
        assert_eq(tokenbuf_count(tb_hand), tokenbuf_count(tb_data),
                  "handcoded/data-driven token count match");
        var tk_n = tokenbuf_count(tb_hand);
        var tk_i = 0;
        while (tk_i < tk_n) {
            assert_eq(tokenbuf_kind(tb_hand, tk_i),
                      tokenbuf_kind(tb_data, tk_i),
                      "kind match");
            assert_eq(tokenbuf_start(tb_hand, tk_i),
                      tokenbuf_start(tb_data, tk_i),
                      "start match");
            assert_eq(tokenbuf_len(tb_hand, tk_i),
                      tokenbuf_len(tb_data, tk_i),
                      "len match");
            tk_i = tk_i + 1;
        }
        pi = pi + 1;
    }

    test_group("M3 toml grammar — loads and tokenizes cleanly");
    var gtoml = grammar_load("grammars/toml.cyml");
    assert_neq(gtoml, 0, "grammar_load toml returned non-null");
    assert_eq(streq(grammar_name(gtoml), "toml"), 1, "name is 'toml'");
    assert_eq(grammar_shebang_on(gtoml),    0, "no shebang for TOML");
    assert_eq(grammar_whitespace_on(gtoml), 1, "whitespace default on");
    assert_eq(grammar_special_vars(gtoml),  0, "no shell special-vars");

    var toml_exts = grammar_extensions(gtoml);
    assert_eq(vec_len(toml_exts), 1, "1 TOML extension");
    assert_eq(streq(vec_get(toml_exts, 0), ".toml"), 1, "ext == '.toml'");

    # Dashed bare keys: `foo-bar = 1` must tokenize foo-bar as one
    # ident (not three tokens), and `1` as a number. This is the
    # ident_start / ident_cont asymmetry (`-` in cont only).
    var tb_tl1 = tokenbuf_new();
    var src_tl1 = "foo-bar = 1";
    tokenize_with_grammar(gtoml, src_tl1, strlen(src_tl1), tb_tl1);
    assert_eq(tokenbuf_count(tb_tl1), 5, "5 tokens: ident ws op ws num");
    assert_eq(tokenbuf_kind(tb_tl1, 0),  TK_IDENT,      "tok0 ident");
    assert_eq(tokenbuf_len(tb_tl1, 0),   7,             "foo-bar len 7");
    assert_eq(tokenbuf_kind(tb_tl1, 2),  TK_OPERATOR,   "tok2 = operator");
    assert_eq(tokenbuf_kind(tb_tl1, 4),  TK_NUMBER,     "tok4 number");

    # Negative number: `-42` is operator + number, not ident.
    var tb_tl2 = tokenbuf_new();
    var src_tl2 = "-42";
    tokenize_with_grammar(gtoml, src_tl2, strlen(src_tl2), tb_tl2);
    assert_eq(tokenbuf_count(tb_tl2), 2, "-42 is two tokens");
    assert_eq(tokenbuf_kind(tb_tl2, 0), TK_OPERATOR, "leading - operator");
    assert_eq(tokenbuf_kind(tb_tl2, 1), TK_NUMBER,   "42 number");

    # [[section]] punctuation.
    var tb_tl3 = tokenbuf_new();
    var src_tl3 = "[[a]]";
    tokenize_with_grammar(gtoml, src_tl3, strlen(src_tl3), tb_tl3);
    assert_eq(tokenbuf_count(tb_tl3), 3, "[[ ident ]] = 3 tokens");
    assert_eq(tokenbuf_kind(tb_tl3, 0), TK_PUNCTUATION, "[[ punct");
    assert_eq(tokenbuf_len(tb_tl3, 0),  2,              "[[ len 2");
    assert_eq(tokenbuf_kind(tb_tl3, 1), TK_IDENT,       "a ident");
    assert_eq(tokenbuf_kind(tb_tl3, 2), TK_PUNCTUATION, "]] punct");
    assert_eq(tokenbuf_len(tb_tl3, 2),  2,              "]] len 2");

    # TOML keywords.
    var tb_tl4 = tokenbuf_new();
    var src_tl4 = "x = true";
    tokenize_with_grammar(gtoml, src_tl4, strlen(src_tl4), tb_tl4);
    assert_eq(tokenbuf_kind(tb_tl4, 4), TK_KEYWORD, "true is keyword");
    assert_eq(tokenbuf_len(tb_tl4, 4),  4,          "true len 4");

    test_group("M3 json grammar — loads and tokenizes cleanly");
    var gjson = grammar_load("grammars/json.cyml");
    assert_neq(gjson, 0, "grammar_load json returned non-null");
    assert_eq(streq(grammar_name(gjson), "json"), 1, "name is 'json'");
    assert_eq(grammar_shebang_on(gjson), 0, "no shebang for JSON");

    # Structural punctuation: `{ "k": 1 }` → 7 tokens.
    var tb_j1 = tokenbuf_new();
    var src_j1 = "{\"k\":1}";
    tokenize_with_grammar(gjson, src_j1, strlen(src_j1), tb_j1);
    assert_eq(tokenbuf_count(tb_j1), 5, "{ \"k\" : 1 } with tight spacing = 5 tokens");
    assert_eq(tokenbuf_kind(tb_j1, 0), TK_PUNCTUATION, "{ punct");
    assert_eq(tokenbuf_kind(tb_j1, 1), TK_STRING,      "\"k\" string");
    assert_eq(tokenbuf_kind(tb_j1, 2), TK_PUNCTUATION, ": punct");
    assert_eq(tokenbuf_kind(tb_j1, 3), TK_NUMBER,      "1 number");
    assert_eq(tokenbuf_kind(tb_j1, 4), TK_PUNCTUATION, "} punct");

    # Keywords: true / false / null.
    var tb_j2 = tokenbuf_new();
    var src_j2 = "[true,false,null]";
    tokenize_with_grammar(gjson, src_j2, strlen(src_j2), tb_j2);
    assert_eq(tokenbuf_kind(tb_j2, 1), TK_KEYWORD, "true keyword");
    assert_eq(tokenbuf_kind(tb_j2, 3), TK_KEYWORD, "false keyword");
    assert_eq(tokenbuf_kind(tb_j2, 5), TK_KEYWORD, "null keyword");

    # Negative number: operator + number.
    var tb_j3 = tokenbuf_new();
    var src_j3 = "-42";
    tokenize_with_grammar(gjson, src_j3, strlen(src_j3), tb_j3);
    assert_eq(tokenbuf_count(tb_j3), 2, "-42 is two tokens");
    assert_eq(tokenbuf_kind(tb_j3, 0), TK_OPERATOR, "- operator");
    assert_eq(tokenbuf_kind(tb_j3, 1), TK_NUMBER,   "42 number");

    # Bare word (invalid JSON but we tokenize permissively): emit
    # as ident rather than error. The scanner has no JSON validator.
    var tb_j4 = tokenbuf_new();
    var src_j4 = "undefined";
    tokenize_with_grammar(gjson, src_j4, strlen(src_j4), tb_j4);
    assert_eq(tokenbuf_count(tb_j4), 1, "bare word is 1 token");
    assert_eq(tokenbuf_kind(tb_j4, 0), TK_IDENT, "bare undefined is ident, not error");

    test_group("M3 cyrius grammar — loads and tokenizes cleanly");
    var gcyr = grammar_load("grammars/cyrius.cyml");
    assert_neq(gcyr, 0, "grammar_load cyrius returned non-null");
    assert_eq(streq(grammar_name(gcyr), "cyrius"), 1, "name is 'cyrius'");

    # `fn` is a keyword; `foo` is an ident.
    var tb_c1 = tokenbuf_new();
    var src_c1 = "fn foo() { return 0; }";
    tokenize_with_grammar(gcyr, src_c1, strlen(src_c1), tb_c1);
    assert_eq(tokenbuf_kind(tb_c1, 0), TK_KEYWORD, "fn keyword");
    assert_eq(tokenbuf_len(tb_c1, 0),  2,          "fn len 2");
    assert_eq(tokenbuf_kind(tb_c1, 2), TK_IDENT,   "foo ident");
    # return is keyword
    var ri = 0;
    var rn = tokenbuf_count(tb_c1);
    var found_return = 0;
    while (ri < rn) {
        if (tokenbuf_kind(tb_c1, ri) == TK_KEYWORD) {
            var s = tokenbuf_start(tb_c1, ri);
            var l = tokenbuf_len(tb_c1, ri);
            if (l == 6) {
                if (memeq(src_c1 + s, "return", 6) == 1) { found_return = 1; }
            }
        }
        ri = ri + 1;
    }
    assert_eq(found_return, 1, "return is a keyword");

    # Hex literal.
    var tb_c2 = tokenbuf_new();
    var src_c2 = "0xFF";
    tokenize_with_grammar(gcyr, src_c2, strlen(src_c2), tb_c2);
    assert_eq(tokenbuf_count(tb_c2), 1,         "0xFF is one token");
    assert_eq(tokenbuf_kind(tb_c2, 0), TK_NUMBER, "0xFF number");
    assert_eq(tokenbuf_len(tb_c2, 0),  4,         "0xFF len 4");

    # `#` starts a comment to EOL (no shebang in Cyrius).
    var tb_c3 = tokenbuf_new();
    var src_c3 = "# hello\nfn x";
    tokenize_with_grammar(gcyr, src_c3, strlen(src_c3), tb_c3);
    assert_eq(tokenbuf_kind(tb_c3, 0), TK_COMMENT, "# comment (not preprocessor)");
    assert_eq(tokenbuf_len(tb_c3, 0),  7,          "# hello len 7");

    test_group("M3 rust grammar — loads and tokenizes cleanly");
    var grust = grammar_load("grammars/rust.cyml");
    assert_neq(grust, 0, "grammar_load rust returned non-null");
    assert_eq(streq(grammar_name(grust), "rust"), 1, "name is 'rust'");

    # `//` line comments, not `#`.
    var tb_r1 = tokenbuf_new();
    var src_r1 = "// hi\nfn f";
    tokenize_with_grammar(grust, src_r1, strlen(src_r1), tb_r1);
    assert_eq(tokenbuf_kind(tb_r1, 0), TK_COMMENT, "// is comment");
    assert_eq(tokenbuf_len(tb_r1, 0),  5,          "// hi len 5");

    # `=>` and `->` multi-char operators.
    var tb_r2 = tokenbuf_new();
    var src_r2 = "a => b -> c";
    tokenize_with_grammar(grust, src_r2, strlen(src_r2), tb_r2);
    assert_eq(tokenbuf_kind(tb_r2, 2), TK_OPERATOR, "=> op");
    assert_eq(tokenbuf_len(tb_r2, 2),  2,           "=> len 2");
    assert_eq(tokenbuf_kind(tb_r2, 6), TK_OPERATOR, "-> op");
    assert_eq(tokenbuf_len(tb_r2, 6),  2,           "-> len 2");

    # `::` path separator, distinct from `:` punctuation.
    var tb_r3 = tokenbuf_new();
    var src_r3 = "std::fmt";
    tokenize_with_grammar(grust, src_r3, strlen(src_r3), tb_r3);
    assert_eq(tokenbuf_count(tb_r3), 3, "3 tokens: ident :: ident");
    assert_eq(tokenbuf_kind(tb_r3, 1), TK_OPERATOR, ":: op");
    assert_eq(tokenbuf_len(tb_r3, 1),  2,           ":: len 2");

    # `#[derive(Debug)]` tokenizes as # op + [ punct + ident + ( + ident + ) + ].
    var tb_r4 = tokenbuf_new();
    var src_r4 = "#[derive]";
    tokenize_with_grammar(grust, src_r4, strlen(src_r4), tb_r4);
    assert_eq(tokenbuf_count(tb_r4), 4, "4 tokens: # [ derive ]");
    assert_eq(tokenbuf_kind(tb_r4, 0), TK_OPERATOR,    "# operator");
    assert_eq(tokenbuf_kind(tb_r4, 1), TK_PUNCTUATION, "[ punct");
    assert_eq(tokenbuf_kind(tb_r4, 2), TK_IDENT,       "derive ident");
    assert_eq(tokenbuf_kind(tb_r4, 3), TK_PUNCTUATION, "] punct");

    test_group("M3 yaml grammar — loads and tokenizes cleanly");
    var gyaml = grammar_load("grammars/yaml.cyml");
    assert_neq(gyaml, 0, "grammar_load yaml returned non-null");
    assert_eq(streq(grammar_name(gyaml), "yaml"), 1, "name is 'yaml'");

    # `key: value` — : is punctuation between idents.
    var tb_y1 = tokenbuf_new();
    var src_y1 = "foo: bar";
    tokenize_with_grammar(gyaml, src_y1, strlen(src_y1), tb_y1);
    assert_eq(tokenbuf_count(tb_y1), 4, "ident : ws ident = 4 tokens");
    assert_eq(tokenbuf_kind(tb_y1, 0), TK_IDENT,       "foo ident");
    assert_eq(tokenbuf_kind(tb_y1, 1), TK_PUNCTUATION, ": punct");
    assert_eq(tokenbuf_kind(tb_y1, 3), TK_IDENT,       "bar ident");

    # Anchor + alias: &x / *x.
    var tb_y2 = tokenbuf_new();
    var src_y2 = "a: &n 1\nb: *n";
    tokenize_with_grammar(gyaml, src_y2, strlen(src_y2), tb_y2);
    var saw_anchor = 0;
    var saw_alias = 0;
    var y2i = 0;
    var y2n = tokenbuf_count(tb_y2);
    while (y2i < y2n) {
        if (tokenbuf_kind(tb_y2, y2i) == TK_OPERATOR) {
            var l = tokenbuf_len(tb_y2, y2i);
            var s = tokenbuf_start(tb_y2, y2i);
            if ((l == 1) && (load8(src_y2 + s) == 38)) { saw_anchor = 1; }
            if ((l == 1) && (load8(src_y2 + s) == 42)) { saw_alias  = 1; }
        }
        y2i = y2i + 1;
    }
    assert_eq(saw_anchor, 1, "& anchor recognized as operator");
    assert_eq(saw_alias,  1, "* alias recognized as operator");

    # Merge-key `<<` is a 2-char operator.
    var tb_y3 = tokenbuf_new();
    var src_y3 = "<<: *x";
    tokenize_with_grammar(gyaml, src_y3, strlen(src_y3), tb_y3);
    assert_eq(tokenbuf_kind(tb_y3, 0), TK_OPERATOR, "<< operator");
    assert_eq(tokenbuf_len(tb_y3, 0),  2,           "<< len 2");

    # Keywords: true/false/null/yes/no/on/off.
    var tb_y4 = tokenbuf_new();
    var src_y4 = "a: yes\nb: no\nc: null\nd: on\ne: off";
    tokenize_with_grammar(gyaml, src_y4, strlen(src_y4), tb_y4);
    var kw_count = 0;
    var y4i = 0;
    var y4n = tokenbuf_count(tb_y4);
    while (y4i < y4n) {
        if (tokenbuf_kind(tb_y4, y4i) == TK_KEYWORD) { kw_count = kw_count + 1; }
        y4i = y4i + 1;
    }
    assert_eq(kw_count, 5, "5 yaml keywords: yes no null on off");

    test_group("M3 markdown grammar — loads and tokenizes cleanly");
    var gmd = grammar_load("grammars/markdown.cyml");
    assert_neq(gmd, 0, "grammar_load markdown returned non-null");
    assert_eq(streq(grammar_name(gmd), "markdown"), 1, "name is 'markdown'");

    # ATX heading operators: longest-first match.
    var tb_m1 = tokenbuf_new();
    var src_m1 = "# Title";
    tokenize_with_grammar(gmd, src_m1, strlen(src_m1), tb_m1);
    assert_eq(tokenbuf_kind(tb_m1, 0), TK_OPERATOR, "# heading marker");
    assert_eq(tokenbuf_len(tb_m1, 0),  1,           "# single char");

    var tb_m2 = tokenbuf_new();
    var src_m2 = "### Sub";
    tokenize_with_grammar(gmd, src_m2, strlen(src_m2), tb_m2);
    assert_eq(tokenbuf_kind(tb_m2, 0), TK_OPERATOR, "### heading 3");
    assert_eq(tokenbuf_len(tb_m2, 0),  3,           "### len 3");

    # Fenced code block (triple-backtick pair) captures the full body
    # including the language tag.
    var tb_m3 = tokenbuf_new();
    var src_m3 = "```rust\nfn x() {}\n```";
    tokenize_with_grammar(gmd, src_m3, strlen(src_m3), tb_m3);
    assert_eq(tokenbuf_count(tb_m3), 1,            "fenced block is one token");
    assert_eq(tokenbuf_kind(tb_m3, 0), TK_STRING,  "fenced block is string");
    assert_eq(tokenbuf_len(tb_m3, 0),  strlen(src_m3), "fenced block covers input");

    # Inline code backticks.
    var tb_m4 = tokenbuf_new();
    var src_m4 = "use `lex()` here";
    tokenize_with_grammar(gmd, src_m4, strlen(src_m4), tb_m4);
    var saw_inline = 0;
    var m4i = 0;
    var m4n = tokenbuf_count(tb_m4);
    while (m4i < m4n) {
        if (tokenbuf_kind(tb_m4, m4i) == TK_STRING) {
            if (tokenbuf_len(tb_m4, m4i) == 7) { saw_inline = 1; }   # `lex()`
        }
        m4i = m4i + 1;
    }
    assert_eq(saw_inline, 1, "inline backtick-pair emits a string token");

    # HTML comment `<!-- ... -->`.
    var tb_m5 = tokenbuf_new();
    var src_m5 = "<!-- hi -->";
    tokenize_with_grammar(gmd, src_m5, strlen(src_m5), tb_m5);
    assert_eq(tokenbuf_count(tb_m5), 1,             "HTML comment is one token");
    assert_eq(tokenbuf_kind(tb_m5, 0), TK_COMMENT,  "HTML comment kind");

    # Emphasis: *italic* and **bold**.
    var tb_m6 = tokenbuf_new();
    var src_m6 = "**bold**";
    tokenize_with_grammar(gmd, src_m6, strlen(src_m6), tb_m6);
    assert_eq(tokenbuf_kind(tb_m6, 0), TK_OPERATOR, "** operator");
    assert_eq(tokenbuf_len(tb_m6, 0),  2,           "** len 2");
    assert_eq(tokenbuf_kind(tb_m6, 1), TK_IDENT,    "bold ident");
    assert_eq(tokenbuf_kind(tb_m6, 2), TK_OPERATOR, "closing **");

    test_group("M3 c grammar — loads and tokenizes cleanly");
    var gc = grammar_load("grammars/c.cyml");
    assert_neq(gc, 0, "grammar_load c returned non-null");
    assert_eq(streq(grammar_name(gc), "c"), 1, "name is 'c'");

    # `//` line comment, not `#`.
    var tb_cc1 = tokenbuf_new();
    var src_cc1 = "// note\nint x;";
    tokenize_with_grammar(gc, src_cc1, strlen(src_cc1), tb_cc1);
    assert_eq(tokenbuf_kind(tb_cc1, 0), TK_COMMENT, "// comment");
    assert_eq(tokenbuf_len(tb_cc1, 0),  7,          "// note len 7");
    assert_eq(tokenbuf_kind(tb_cc1, 2), TK_KEYWORD, "int keyword");

    # `->` and `++` multi-char operators.
    var tb_cc2 = tokenbuf_new();
    var src_cc2 = "p->n++";
    tokenize_with_grammar(gc, src_cc2, strlen(src_cc2), tb_cc2);
    assert_eq(tokenbuf_count(tb_cc2), 4, "p -> n ++ = 4 tokens");
    assert_eq(tokenbuf_kind(tb_cc2, 1), TK_OPERATOR, "-> op");
    assert_eq(tokenbuf_len(tb_cc2, 1),  2,           "-> len 2");
    assert_eq(tokenbuf_kind(tb_cc2, 3), TK_OPERATOR, "++ op");
    assert_eq(tokenbuf_len(tb_cc2, 3),  2,           "++ len 2");

    # Preprocessor-shaped line tokenizes as # + ident + ... (no
    # special preprocessor kind in M3).
    var tb_cc3 = tokenbuf_new();
    var src_cc3 = "#include";
    tokenize_with_grammar(gc, src_cc3, strlen(src_cc3), tb_cc3);
    assert_eq(tokenbuf_count(tb_cc3), 2, "# + include = 2 tokens");
    assert_eq(tokenbuf_kind(tb_cc3, 0), TK_OPERATOR, "# operator");
    assert_eq(tokenbuf_kind(tb_cc3, 1), TK_IDENT,    "include ident (not a C keyword)");

    # Backslash in char escape like '\0' must not error.
    var tb_cc4 = tokenbuf_new();
    var src_cc4 = "char c = '\\0';";
    tokenize_with_grammar(gc, src_cc4, strlen(src_cc4), tb_cc4);
    var cc4i = 0;
    var cc4n = tokenbuf_count(tb_cc4);
    var any_err = 0;
    while (cc4i < cc4n) {
        if (tokenbuf_kind(tb_cc4, cc4i) == TK_ERROR) { any_err = 1; }
        cc4i = cc4i + 1;
    }
    assert_eq(any_err, 0, "char-escape backslash doesn't error");

    test_group("M3 typescript grammar — loads and tokenizes cleanly");
    var gts = grammar_load("grammars/typescript.cyml");
    assert_neq(gts, 0, "grammar_load typescript returned non-null");
    assert_eq(streq(grammar_name(gts), "typescript"), 1, "name is 'typescript'");

    # Template literal `...${expr}...` as one string token.
    var tb_t1 = tokenbuf_new();
    var src_t1 = "`hi ${x} bye`";
    tokenize_with_grammar(gts, src_t1, strlen(src_t1), tb_t1);
    assert_eq(tokenbuf_count(tb_t1), 1, "template literal is one token");
    assert_eq(tokenbuf_kind(tb_t1, 0), TK_STRING, "template is string");

    # `=>` arrow, `??` nullish coalesce, `?.` optional chain.
    var tb_t2 = tokenbuf_new();
    var src_t2 = "a => b ?? c?.d";
    tokenize_with_grammar(gts, src_t2, strlen(src_t2), tb_t2);
    var saw_arrow = 0;
    var saw_coalesce = 0;
    var saw_optchain = 0;
    var t2i = 0;
    var t2n = tokenbuf_count(tb_t2);
    while (t2i < t2n) {
        if (tokenbuf_kind(tb_t2, t2i) == TK_OPERATOR) {
            var s = tokenbuf_start(tb_t2, t2i);
            var l = tokenbuf_len(tb_t2, t2i);
            if ((l == 2) && (memeq(src_t2 + s, "=>", 2) == 1)) { saw_arrow = 1; }
            if ((l == 2) && (memeq(src_t2 + s, "??", 2) == 1)) { saw_coalesce = 1; }
            if ((l == 2) && (memeq(src_t2 + s, "?.", 2) == 1)) { saw_optchain = 1; }
        }
        t2i = t2i + 1;
    }
    assert_eq(saw_arrow,    1, "=> op");
    assert_eq(saw_coalesce, 1, "?? op");
    assert_eq(saw_optchain, 1, "?. op");

    # `$` is valid in idents: `$x`, `jQuery$`.
    var tb_t3 = tokenbuf_new();
    var src_t3 = "$foo";
    tokenize_with_grammar(gts, src_t3, strlen(src_t3), tb_t3);
    assert_eq(tokenbuf_count(tb_t3), 1,          "$foo is one token");
    assert_eq(tokenbuf_kind(tb_t3, 0), TK_IDENT, "$foo ident");
    assert_eq(tokenbuf_len(tb_t3, 0),  4,        "$foo len 4");

    test_group("M3 javascript grammar — loads and tokenizes cleanly");
    var gjs = grammar_load("grammars/javascript.cyml");
    assert_neq(gjs, 0, "grammar_load javascript returned non-null");
    assert_eq(streq(grammar_name(gjs), "javascript"), 1, "name is 'javascript'");

    # JS has `function` as keyword but no `interface` / `type`.
    var tb_js1 = tokenbuf_new();
    var src_js1 = "function f() {}";
    tokenize_with_grammar(gjs, src_js1, strlen(src_js1), tb_js1);
    assert_eq(tokenbuf_kind(tb_js1, 0), TK_KEYWORD, "function keyword");
    assert_eq(tokenbuf_len(tb_js1, 0),  8,          "function len 8");

    var tb_js2 = tokenbuf_new();
    var src_js2 = "interface F";
    tokenize_with_grammar(gjs, src_js2, strlen(src_js2), tb_js2);
    assert_eq(tokenbuf_kind(tb_js2, 0), TK_IDENT, "interface is NOT a JS keyword");

    test_group("M3 python grammar — loads and tokenizes cleanly");
    var gpy = grammar_load("grammars/python.cyml");
    assert_neq(gpy, 0, "grammar_load python returned non-null");
    assert_eq(streq(grammar_name(gpy), "python"), 1, "name is 'python'");

    # Triple-quoted string as ONE token (pair rule ordering).
    var tb_py1 = tokenbuf_new();
    var src_py1 = "\"\"\"docstring here\"\"\"";
    tokenize_with_grammar(gpy, src_py1, strlen(src_py1), tb_py1);
    assert_eq(tokenbuf_count(tb_py1), 1,          "triple-quoted is one token");
    assert_eq(tokenbuf_kind(tb_py1, 0), TK_STRING, "triple-quoted is string");
    assert_eq(tokenbuf_len(tb_py1, 0), strlen(src_py1), "covers whole input");

    # Walrus := as a 2-char operator.
    var tb_py2 = tokenbuf_new();
    var src_py2 = "(x := 1)";
    tokenize_with_grammar(gpy, src_py2, strlen(src_py2), tb_py2);
    var saw_walrus = 0;
    var py2i = 0;
    var py2n = tokenbuf_count(tb_py2);
    while (py2i < py2n) {
        if (tokenbuf_kind(tb_py2, py2i) == TK_OPERATOR) {
            if (tokenbuf_len(tb_py2, py2i) == 2) {
                var s = tokenbuf_start(tb_py2, py2i);
                if (memeq(src_py2 + s, ":=", 2) == 1) { saw_walrus = 1; }
            }
        }
        py2i = py2i + 1;
    }
    assert_eq(saw_walrus, 1, ":= walrus op");

    # `//` is floor division, NOT a comment in Python.
    var tb_py3 = tokenbuf_new();
    var src_py3 = "a // b";
    tokenize_with_grammar(gpy, src_py3, strlen(src_py3), tb_py3);
    assert_eq(tokenbuf_kind(tb_py3, 2), TK_OPERATOR, "// floor-div op, not comment");
    assert_eq(tokenbuf_len(tb_py3, 2),  2,           "// len 2");

    # `#` still starts a line comment.
    var tb_py4 = tokenbuf_new();
    var src_py4 = "# py comment\nx";
    tokenize_with_grammar(gpy, src_py4, strlen(src_py4), tb_py4);
    assert_eq(tokenbuf_kind(tb_py4, 0), TK_COMMENT, "# still a comment");

    test_group("version string shape");
    # Keep in sync with VYK_VERSION in src/main.cyr and with VERSION.
    var v = "vyk 0.1.0";
    assert(strlen(v) > 4, "version string is longer than 4 chars");
    assert_eq(memeq(v, "vyk ", 4), 1, "version string starts with 'vyk '");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
